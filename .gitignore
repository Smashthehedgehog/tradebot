# Virtual Environment
.venv/

# RSA key for SSH access to EC2 instance. Ignore this so it doesn't get accidentally committed.
tradebot-ssh.pem

# Environment variables containing sensitive credentials. Ignore this so they don't get accidentally committed.
.env

# Bytecode and logs generated by the code. Ignore these so they don't clutter the repo.
__pycache__/
logs/*
!logs/console.log
!logs/trading_bot.log
