            style="rounded=1;whiteSpace=wrap;html=1;align=left;
                   fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;"
            vertex="1" parent="34">
      <mxGeometry x="20" y="198" width="520" height="100" as="geometry"/>
